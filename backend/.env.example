ENVIRONMENT=development

# Postgres via Supabase in staging/production; SQLite is fine for local dev.
DATABASE_URL=sqlite:///./dev.db

JWT_SECRET_KEY=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

REDIS_URL=redis://localhost:6379/0

# Leave blank to use local-disk storage fallback in development.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=g-erp-documents

LOCAL_STORAGE_DIR=./storage_data

CORS_ALLOW_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_METHODS=["GET", "POST", "PATCH", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization", "Content-Type", "X-Request-ID"]

# Protects stored third-party integration credentials (WhatsApp/Twilio/SMTP/
# IMAP tokens and passwords) at rest. Change this in every real environment.
CHANNEL_CREDENTIALS_ENCRYPTION_KEY=change-me-to-a-long-random-value
